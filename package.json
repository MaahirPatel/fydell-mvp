{
  "name": "fydell-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:sim && next build",
    "build:next": "next build",
    "build:sim": "esbuild js/sim/browser-entry.js --bundle --format=iife --outfile=sim-engine.js --platform=browser --target=es2018 --loader:.ts=ts --loader:.json=json",
    "build:sim:node": "esbuild js/sim/index.js --bundle --format=cjs --outfile=sim-engine.cjs --platform=node --target=node18 --loader:.ts=ts --loader:.json=json",
    "smoke:sim": "node scripts/smoke-meridian.js",
    "eval:session": "node scripts/eval-session.js",
    "accept:meridian": "node scripts/accept-meridian.mjs both",
    "accept:strong": "node scripts/accept-meridian.mjs strong",
    "accept:weak": "node scripts/accept-meridian.mjs weak",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:unit": "npx tsx scripts/test-pilot-validation.ts && npx tsx scripts/test-pilot-lifecycle.ts",
    "test:e2e": "playwright test",
    "verify:migrations": "npx tsx scripts/verify-migration-state.ts",
    "bootstrap:admin": "npx tsx scripts/bootstrap-platform-admin.ts",
    "admin:password": "npx tsx scripts/set-admin-password.ts --write",
    "verify:prod": "npx tsx scripts/verify-production-readiness.ts",
    "seed:dev": "ALLOW_DEV_SEED=true npx tsx scripts/seed-development.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "geist": "^1.7.2",
    "jose": "^6.2.3",
    "lenis": "^1.3.24",
    "lucide-react": "^0.468.0",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.0",
    "resend": "^6.14.0",
    "server-only": "^0.0.1",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.25.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
